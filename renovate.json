{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "ignorePresets": [
    "group:springBoot",
    "group:springCloud",
    "group:springWs",
    "group:kotlinMonorepo",
    "group:typescriptEslintMonorepo"
  ],
  "timezone": "Europe/Zurich",
  "ignorePaths": [
    "hello-data-portal/hello-data-portal-ui-e2e/**",
    "**/requirements*.txt"
  ],
  "enabledManagers": [
    "maven",
    "npm"
  ],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  },
  "prHourlyLimit": 0,
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "description": "Security updates: auto-create PRs immediately, bypass approval and grouping",
      "matchCategories": [
        "security"
      ],
      "dependencyDashboardApproval": false,
      "automerge": false,
      "groupName": null,
      "prPriority": 10,
      "schedule": [
        "at any time"
      ],
      "platformAutomerge": false
    },
    {
      "description": "Ignore internal Maven packages that Renovate cannot resolve",
      "matchManagers": [
        "maven"
      ],
      "matchPackageNames": [
        "/^ch\\.bedag\\.dap\\.hellodata:/"
      ],
      "enabled": false
    },
    {
      "description": "Pin spring-cloud-dependencies to 2025.0.x (2025.1.x targets Spring Boot 4.0.x)",
      "matchManagers": [
        "maven"
      ],
      "matchPackageNames": [
        "org.springframework.cloud:spring-cloud-dependencies"
      ],
      "allowedVersions": "<2025.1.0"
    },
    {
      "description": "Group all Spring packages (minor/patch)",
      "matchManagers": [
        "maven"
      ],
      "matchPackageNames": [
        "/^org\\.springframework/"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Spring packages (minor/patch)",
      "groupSlug": "spring-minor-patch"
    },
    {
      "description": "Group all Angular packages (minor/patch)",
      "matchManagers": [
        "npm"
      ],
      "matchPackageNames": [
        "/^@angular\\//",
        "/^@angular-/",
        "/^angular-auth-oidc-client/",
        "/^primeng/",
        "/^@ngrx\\//",
        "/^@schematics\\//",
        "/^ng-packagr/",
        "/^zone\\.js/",
        "/^rxjs/",
        "/^tslib/"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Angular packages (minor/patch)",
      "groupSlug": "angular-minor-patch"
    },
    {
      "description": "Group remaining Java/Maven packages (minor/patch)",
      "matchManagers": [
        "maven"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Java packages (minor/patch)",
      "groupSlug": "java-minor-patch",
      "matchPackageNames": [
        "!/^org\\.springframework/",
        "!/^ch\\.bedag\\.dap\\.hellodata:/"
      ]
    },
    {
      "description": "Group remaining npm/yarn packages (minor/patch)",
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "npm packages (minor/patch)",
      "groupSlug": "npm-minor-patch",
      "matchPackageNames": [
        "!/^@angular\\//",
        "!/^@angular-/",
        "!/^angular-auth-oidc-client/",
        "!/^primeng/",
        "!/^@ngrx\\//",
        "!/^@schematics\\//",
        "!/^ng-packagr/",
        "!/^zone\\.js/",
        "!/^rxjs/",
        "!/^tslib/"
      ]
    },
    {
      "description": "Group all Angular major updates",
      "matchManagers": [
        "npm"
      ],
      "matchPackageNames": [
        "/^@angular\\//",
        "/^@angular-/",
        "/^angular-auth-oidc-client/",
        "/^@ngrx\\//",
        "/^primeng/",
        "/^@schematics\\//",
        "/^ng-packagr/",
        "/^zone\\.js/",
        "/^rxjs/",
        "/^tslib/"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true,
      "groupName": "Angular packages",
      "groupSlug": "angular-major"
    },
    {
      "description": "Group all Spring major updates",
      "matchManagers": [
        "maven"
      ],
      "matchPackageNames": [
        "/^org\\.springframework/"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true,
      "groupName": "Spring packages",
      "groupSlug": "spring-major"
    },
    {
      "description": "Each remaining major update gets its own PR",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true,
      "groupName": "major update: {{depName}}",
      "groupSlug": "major-{{depName}}",
      "matchPackageNames": [
        "!/^@angular\\//",
        "!/^@angular-/",
        "!/^angular-auth-oidc-client/",
        "!/^@ngrx\\//",
        "!/^@schematics\\//",
        "!/^ng-packagr/",
        "!/^zone\\.js/",
        "!/^rxjs/",
        "!/^tslib/",
        "!/^org\\.springframework/",
        "!/^ch\\.bedag\\.dap\\.hellodata:/",
        "!/^@fortawesome\\//",
        "!/^primeng/"
      ]
    }
  ]
}